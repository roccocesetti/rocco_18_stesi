<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="view_mrp_production_overview_wizard_form" model="ir.ui.view">
        <field name="name">mrp.production.overview.wizard.form</field>
        <field name="model">mrp.production.overview.wizard</field>
        <field name="arch" type="xml">
            <form string="Panoramica ordini di produzione">
                <sheet>
                    <group>
                        <field name="production_ids" widget="many2many_tags" readonly="1"/>
                    </group>

                    <field name="line_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0">
                            <field name="production_id"/>
                            <field name="product_finished_id"/>
                            <field name="component_id"/>
                            <field name="qty_required"/>
                            <field name="uom_id"/>
                            <field name="qty_available"/>
                            <field name="qty_reserved"/>
                            <field name="shortage_qty"/>
                            <field name="status"/>
                            <field name="date_planned_start"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button string="Chiudi" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

<record id="view_mrp_production_overview_wizard_line_list" model="ir.ui.view">
    <field name="name">mrp.production.overview.wizard.line.list</field>
    <field name="model">mrp.production.overview.wizard.line</field>
    <field name="arch" type="xml">
        <list create="0" delete="0">
            <field name="production_id"/>
            <field name="product_finished_id"/>
            <field name="component_id"/>
            <field name="qty_required"/>
            <field name="uom_id"/>
            <field name="qty_available"/>
            <field name="qty_reserved"/>
            <field name="shortage_qty"/>
            <field name="status"/>
            <field name="date_planned_start"/>
        </list>
    </field>
</record>

    <record id="action_mrp_production_multi_overview" model="ir.actions.server">
        <field name="name">Panoramica multipla</field>
        <field name="model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = env['mrp.production.overview.wizard'].action_open_from_productions()
        </field>
    </record>

    <record id="action_mrp_production_reorder_components" model="ir.actions.server">
        <field name="name">Riordina componenti MO</field>
        <field name="model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = env['mrp.production.overview.wizard'].action_reorder_components_from_productions()
        </field>
    </record>



<record id="action_mrp_overview_line_reorder" model="ir.actions.server">
    <field name="name">Riordina</field>
    <field name="model_id" ref="model_mrp_production_overview_wizard_line"/>
    <field name="binding_model_id" ref="model_mrp_production_overview_wizard_line"/>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="code">
action = records.action_replenish()
    </field>
</record>

</odoo>